# ─────────────────────────────────────────────────────────────
# weight-coach – Konfiguration
# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# ─────────────────────────────────────────────────────────────

# Port des lokalen Servers
PORT=5173

# Storage-Backend: "local" (JSON-Datei) oder "sheets" (Google Sheets)
# Lässt du es leer und ist kein Sheet konfiguriert, startet die App
# automatisch im lokalen Modus mit Demodaten.
STORAGE=sheets

# ── Google Sheets (nur nötig bei STORAGE=sheets) ──────────────
# Die ID steht in der URL deines Sheets:
# https://docs.google.com/spreadsheets/d/<DIESE_ID>/edit
GOOGLE_SHEET_ID=

# Pfad zur Service-Account-JSON-Datei (lokaler Betrieb; siehe README)
GOOGLE_CREDENTIALS_FILE=./credentials/service-account.json

# Für Cloud-Hosting (z. B. Vercel) statt der Datei: den GESAMTEN Inhalt der
# service-account.json als eine Umgebungsvariable setzen. Hat Vorrang vor der Datei.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}

# Optionaler simpler Zugriffsschutz: wenn gesetzt, muss die Web-App
# beim Öffnen dieses Passwort abfragen (Basic-Gate, für privaten Gebrauch).
# Leer lassen = kein Passwortschutz.
APP_PASSWORD=

# ── KI-Coach (optional) ───────────────────────────────────────
# Anthropic-API-Schlüssel für den KI-Coach (Plan-Anpassungen).
# Ohne Schlüssel funktioniert alles außer dem Coach-Button.
# Schlüssel erstellen: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: Modell für den Coach (Standard: claude-opus-4-8).
# Günstiger: claude-sonnet-5 oder claude-haiku-4-5.
COACH_MODEL=claude-opus-4-8
